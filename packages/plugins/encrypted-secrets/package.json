  "bugs": {
    "url": "https://github.com/RhysSullivan/executor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RhysSullivan/executor.git",
    "directory": "packages/plugins/encrypted-secrets"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
