  "dependencies": {
    "@executor-js/sdk": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "bun-types": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
