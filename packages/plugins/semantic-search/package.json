{
  "name": "@executor-js/plugin-semantic-search",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/sdk/index.ts",
    "./api": "./src/api/index.ts"
  },
  "scripts": {
    "build": "tsup && (tsc --declaration --emitDeclarationOnly --outDir dist --rootDir src || true)",
