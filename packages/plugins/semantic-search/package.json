    "test:watch": "vitest",
    "eval": "bun run src/sdk/eval.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@executor-js/sdk": "workspace:*",
    "ai": "^6.0.191",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@effect/vitest": "catalog:",
    "@executor-js/api": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "@zvec/zvec": "^0.4.1",
    "better-sqlite3": "^11.10.0",
    "bun-types": "catalog:",
    "sqlite-vec": "^0.1.7",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@executor-js/api": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@executor-js/api": {
      "optional": true
    }
