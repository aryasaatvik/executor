    "test:watch": "bunx --bun vitest"
  },
  "dependencies": {
    "@executor-js/sdk": "workspace:*",
    "effect": "catalog:"
  },
  "peerDependencies": {
    "@executor-js/api": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@executor-js/api": "workspace:*",
    "@types/node": "catalog:",
    "bun-types": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
