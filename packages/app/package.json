    "./index.html": "./index.html"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./src/entry-client.tsx",
      "./vite": {
        "types": "./vite.ts",
        "default": "./vite.js"
      },
      "./router": "./src/router.tsx",
      "./routeTree": "./src/routeTree.gen.ts",
      "./index.html": "./index.html"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "build:web": "vite build",
    "preview": "vite preview",
