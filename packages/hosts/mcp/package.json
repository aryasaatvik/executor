{
  "name": "@executor-js/host-mcp",
  "version": "1.4.4",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tool-server": {
      "types": "./src/tool-server.ts",
      "default": "./src/tool-server.ts"
    },
    "./in-memory-session-store": {
      "types": "./src/in-memory-session-store.ts",
      "default": "./src/in-memory-session-store.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./tool-server": {
        "import": {
          "types": "./dist/tool-server.d.ts",
          "default": "./dist/tool-server.js"
        }
      },
      "./in-memory-session-store": {
        "import": {
          "types": "./dist/in-memory-session-store.d.ts",
          "default": "./dist/in-memory-session-store.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup && (tsc --declaration --emitDeclarationOnly --outDir dist --rootDir src || true)",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:slow": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@executor-js/execution": "workspace:*",
    "@executor-js/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "effect": "catalog:",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "bun-types": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
