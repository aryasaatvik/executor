{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["bun-types", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/server/api/**/*.ts",
    "src/server/rpc/**/*.ts",
    "src/server/index.ts",
"src/server/config.ts",
    "src/server/tracing.ts",
    "src/server/effect-errors.ts",
    "src/server/env.ts"
  ]
}
