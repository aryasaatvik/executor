{
  "version": 1,
  "source": {
    "repo": "RhysSullivan/executor",
    "ref": "main",
    "templatesDir": "templates"
  },
  "targets": {
    "cloudflare": {
      "base": {
        "dir": "cloudflare/base",
        "dependencies": {
          "@executor-js/api": "latest",
          "@executor-js/app": "latest",
          "@executor-js/execution": "latest",
          "@executor-js/host-mcp": "latest",
          "@executor-js/react": "latest",
          "@executor-js/sdk": "latest",
          "@executor-js/plugin-encrypted-secrets": "latest",
          "@executor-js/plugin-graphql": "latest",
          "@executor-js/plugin-mcp": "latest",
          "@executor-js/plugin-openapi": "latest",
          "fumadb": "latest",
          "effect": "4.0.0-beta.59",
          "drizzle-orm": "^0.45.0",
          "jose": "^5.9.6",
          "@modelcontextprotocol/sdk": "^1.29.0",
          "agents": "^0.10.0",
          "@effect/atom-react": "4.0.0-beta.59",
          "@tanstack/react-router": "^1.168.10",
          "react": "^19.1.0",
          "react-dom": "^19.1.0"
        },
        "devDependencies": {
          "@cloudflare/workers-types": "^4.20250410.0",
          "@executor-js/vite-plugin": "latest",
          "@tailwindcss/vite": "^4.2.2",
          "@tanstack/router-plugin": "^1.167.12",
          "@types/node": "^24.3.1",
          "@types/react": "^19.1.0",
          "@types/react-dom": "^19.1.0",
          "@vitejs/plugin-react": "^6.0.1",
          "typescript": "^5.9.3",
          "vite": "^8.0.0",
          "wrangler": "^4.95.0"
        },
        "envVars": {
          "EXECUTOR_SECRET_KEY": "",
          "ACCESS_TEAM_DOMAIN": "your-team.cloudflareaccess.com",
          "ACCESS_AUD": "",
          "ADMIN_EMAILS": "",
          "SELF_HOSTED_ORG_ID": "default",
          "SELF_HOSTED_ORG_NAME": "Default"
        }
      },
      "overlays": [
        {
          "dir": "cloudflare/adapter",
          "dependencies": {
            "@executor-js/api": "latest",
            "@executor-js/execution": "latest",
            "@executor-js/host-mcp": "latest",
            "@modelcontextprotocol/sdk": "^1.29.0",
            "agents": "^0.10.0",
            "effect": "4.0.0-beta.59"
          }
        }
      ],
      "engines": {
        "default": "dynamic-worker",
        "choices": {
          "dynamic-worker": {
            "dir": "cloudflare/engine-dynamic-worker",
            "dependencies": {
              "@executor-js/runtime-dynamic-worker": "latest"
            }
          },
          "quickjs": {
            "dir": "cloudflare/engine-quickjs",
            "dependencies": {
              "@executor-js/runtime-quickjs": "latest",
              "@jitl/quickjs-wasmfile-release-sync": "0.31.0",
              "quickjs-emscripten-core": "0.31.0"
            }
          }
        }
      },
      "plugins": [
        "openapi",
        "mcp",
        "graphql"
      ],
      "pluginRegistry": {
        "openapi": {
          "dependencies": {
            "@executor-js/plugin-openapi": "latest"
          }
        },
        "mcp": {
          "dependencies": {
            "@executor-js/plugin-mcp": "latest"
          }
        },
        "graphql": {
          "dependencies": {
            "@executor-js/plugin-graphql": "latest"
          }
        }
      },
      "packageJsonFrom": "base"
    },
    "selfhost": {
      "base": {
        "dir": "selfhost/base",
        "dependencies": {
          "@executor-js/api": "latest",
          "@executor-js/app": "latest",
          "@executor-js/execution": "latest",
          "@executor-js/host-mcp": "latest",
