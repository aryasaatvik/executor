# Self-hosted Executor — optional configuration.
#
# Every setting is optional: a bare `docker compose up` boots a working instance
# and walks you through creating the admin account in the browser. Copy this file
# to `.env` and uncomment only what you need (compose loads `.env` automatically).

# The public URL browsers use to reach the instance. Must match exactly
# (scheme + host + port) or browser logins are rejected. Set this when serving
# behind a domain / TLS.
# EXECUTOR_WEB_BASE_URL=http://localhost:4788

# Session secret. Auto-generated + persisted under the data volume if unset; set
# it (>= 32 chars) to manage it yourself. Rotating it signs everyone out.
# BETTER_AUTH_SECRET=

# Set BOTH to pre-create the admin instead of the first-run browser setup
# (CI / infra-as-code).
# EXECUTOR_BOOTSTRAP_ADMIN_EMAIL=
# EXECUTOR_BOOTSTRAP_ADMIN_PASSWORD=
# EXECUTOR_BOOTSTRAP_ADMIN_NAME=Admin

# Name and slug for the single organization.
# EXECUTOR_ORG_NAME=Default
# EXECUTOR_ORG_SLUG=default

# Allow sandboxed code to reach loopback / private network addresses.
# EXECUTOR_ALLOW_LOCAL_NETWORK=false
